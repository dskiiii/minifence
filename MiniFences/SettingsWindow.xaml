<Window x:Class="MiniFences.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiniFences Settings"
        Icon="/Assets/AppIcon.ico"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6F8FC"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="15,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#FF1F2937" />
            <Setter Property="BorderBrush" Value="#FFCBD4E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFF3F6FB" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFAAB8CC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonBorder" Property="Background" Value="#FFE7EDF7" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ButtonBorder" Property="Opacity" Value="0.46" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF18202A" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="SectionDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FF5E6875" />
            <Setter Property="Margin" Value="0,0,0,24" />
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF202832" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFD5DDE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="IconGridItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="Transparent" /><Setter Property="BorderBrush" Value="Transparent" /><Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="6"><ContentPresenter /></Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#FFF0F5FF" /></Trigger>
                    <Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#FFE3EDFF" /></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="TransferButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="44" /><Setter Property="Height" Value="44" /><Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="8,5" /><Setter Property="FontSize" Value="20" /><Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" /><Setter Property="Background" Value="#FF2F6FED" /><Setter Property="BorderBrush" Value="#FF2F6FED" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="TransferBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="22">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="TransferBorder" Property="Background" Value="#FF245BCB" /><Setter TargetName="TransferBorder" Property="BorderBrush" Value="#FF245BCB" /></Trigger>
                    <Trigger Property="IsPressed" Value="True"><Setter TargetName="TransferBorder" Property="Background" Value="#FF1D4CA8" /></Trigger>
                    <Trigger Property="IsEnabled" Value="False"><Setter TargetName="TransferBorder" Property="Opacity" Value="0.42" /></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFECF1F8" BorderBrush="#FFD3DCE8" BorderThickness="0,0,1,0">
            <DockPanel Margin="14,22">
                <StackPanel DockPanel.Dock="Top" Margin="8,0,8,22">
                    <TextBlock Text="MiniFences" FontSize="24" FontWeight="SemiBold" Foreground="#FF151B23" />
                    <TextBlock x:Name="SettingsCaptionText" Text="Settings" Margin="0,3,0,0" Foreground="#FF66717E" />
                </StackPanel>
                <ListBox x:Name="NavigationList"
                         SelectionChanged="NavigationList_SelectionChanged"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="15">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="14,11" />
                            <Setter Property="Margin" Value="0,3" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Foreground" Value="#FF344054" />
                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="NavBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ContentPresenter /></Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="NavBorder" Property="Background" Value="#FFF4F7FB" /></Trigger>
                                    <Trigger Property="IsSelected" Value="True"><Setter TargetName="NavBorder" Property="Background" Value="#FFDCE9FF" /><Setter Property="Foreground" Value="#FF1849A9" /><Setter Property="FontWeight" Value="SemiBold" /></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate></Setter.Value></Setter>
                        </Style>
                    </ListBox.Resources>
                    <ListBoxItem x:Name="WelcomeNav" Tag="Welcome" Content="Welcome" />
                    <ListBoxItem x:Name="FencesNav" Tag="Fences" Content="Fences" />
                    <ListBoxItem x:Name="PagesNav" Tag="Pages" Content="Pages" />
                    <ListBoxItem x:Name="LayoutsNav" Tag="Layouts" Content="Layout management" />
                    <ListBoxItem x:Name="OrganizeNav" Tag="Organize" Content="Organization" />
                    <ListBoxItem x:Name="VisibilityNav" Tag="Visibility" Content="Visibility" />
                    <ListBoxItem x:Name="RollupNav" Tag="Rollup" Content="Roll-up" />
                    <ListBoxItem x:Name="TabsNav" Tag="Tabs" Content="Tabs" />
                    <ListBoxItem x:Name="PersonalizeNav" Tag="Appearance" Content="Appearance" />
                    <ListBoxItem x:Name="GeneralNav" Tag="General" Content="General" />
                    <ListBoxItem x:Name="AboutNav" Tag="About" Content="About" />
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="38,30,40,32">
            <Grid x:Name="WelcomePanel">
                <StackPanel>
                    <TextBlock x:Name="WelcomeTitle" Style="{StaticResource SectionTitle}" Text="Welcome to MiniFences" />
                    <TextBlock x:Name="WelcomeDescription" Style="{StaticResource SectionDescription}" Text="Manage your desktop Fences from one place." />
                    <TextBlock x:Name="OverviewTitle" Style="{StaticResource GroupTitle}" Text="Overview" />
                    <Border Background="White" BorderBrush="#FFDDE1E6" BorderThickness="1" Padding="20" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="FenceCountValue" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock x:Name="FenceCountLabel" Text="Fences" Foreground="#FF697481" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="PageCountValue" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock x:Name="PageCountLabel" Text="Pages" Foreground="#FF697481" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="VisibilityValue" FontSize="20" FontWeight="SemiBold" Margin="0,7,0,6" />
                                <TextBlock x:Name="VisibilityLabel" Text="Desktop visibility" Foreground="#FF697481" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="QuickActionsTitle" Style="{StaticResource GroupTitle}" Text="Quick actions" Margin="0,26,0,12" />
                    <WrapPanel>
                        <Button x:Name="WelcomeNewFenceButton" Content="New Fence" Click="NewFenceButton_Click" />
                        <Button x:Name="WelcomeRefreshButton" Content="Refresh all" Click="RefreshButton_Click" />
                        <Button x:Name="WelcomeToggleButton" Content="Disable MiniFences" Click="WelcomeIntegrationButton_Click" />
                        <Button x:Name="WelcomeTopmostButton" Content="Pin Fences on top" Click="TopmostButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <Grid x:Name="FencesPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="170" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="FencesTitle" Style="{StaticResource SectionTitle}" Text="Fences" />
                    <TextBlock x:Name="FencesDescription" Style="{StaticResource SectionDescription}" Text="Manage titles and bound folders." />
                </StackPanel>
                <ListBox x:Name="FenceList" Grid.Row="1" BorderBrush="#FFD7DCE2" SelectionChanged="FenceList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding FolderPath}" Foreground="#FF626E7A" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding DisplayPage}" Foreground="#FF626E7A" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <WrapPanel Grid.Row="2" Margin="0,14,0,0">
                    <Button x:Name="AddFenceButton" Content="New Fence" Click="NewFenceButton_Click" />
                    <Button x:Name="RenameFenceButton" Content="Rename" Click="RenameFenceButton_Click" />
                    <Button x:Name="ChooseFolderButton" Content="Choose folder" Click="ChooseFolderButton_Click" />
                    <Button x:Name="OpenFolderButton" Content="Open folder" Click="OpenFolderButton_Click" />
                    <Button x:Name="DeleteFenceButton" Content="Delete" Click="DeleteFenceButton_Click" />
                    <TextBlock x:Name="FencePageLabel" Text="Page" VerticalAlignment="Center" Margin="18,0,8,8" />
                    <ComboBox x:Name="FencePageComboBox" Width="110" SelectionChanged="FencePageComboBox_SelectionChanged" Margin="0,0,0,8" />
                </WrapPanel>
                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="14">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="2,0,2,10">
                                <TextBlock x:Name="UnassignedItemsTitle" Style="{StaticResource GroupTitle}" Margin="0" Text="Unassigned desktop icons" />
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#FFE8F0FF" CornerRadius="10" Padding="8,3"><TextBlock Text="{Binding ElementName=UnassignedItemsList, Path=Items.Count}" Foreground="#FF2357B6" FontSize="12" FontWeight="SemiBold" /></Border>
                            </Grid>
                            <ListBox x:Name="UnassignedItemsList" SelectionMode="Extended" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource IconGridItem}">
                                <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                                <ListBox.ItemTemplate><DataTemplate><StackPanel Width="72" Height="76" VerticalAlignment="Center"><Image Source="{Binding Icon}" Width="38" Height="38" Stretch="Uniform" /><TextBlock Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="11" Margin="0,7,0,0" ToolTip="{Binding Name}" /></StackPanel></DataTemplate></ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Button x:Name="AssignItemsButton" Style="{StaticResource TransferButton}" ToolTip="Assign selected icons" Click="AssignItemsButton_Click">
                            <Path Width="17" Height="12" Stretch="Fill" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M 0,6 L 16,6 M 10,0 L 16,6 L 10,12" />
                        </Button>
                        <Button x:Name="UnassignItemsButton" Style="{StaticResource TransferButton}" ToolTip="Remove selected icons" Click="UnassignItemsButton_Click">
                            <Path Width="17" Height="12" Stretch="Fill" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M 16,6 L 0,6 M 6,0 L 0,6 L 6,12" />
                        </Button>
                    </StackPanel>
                    <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="14">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="2,0,2,10">
                                <TextBlock x:Name="FenceItemsTitle" Style="{StaticResource GroupTitle}" Margin="0" Text="Fence contents" />
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#FFE8F0FF" CornerRadius="10" Padding="8,3"><TextBlock Text="{Binding ElementName=FenceItemsList, Path=Items.Count}" Foreground="#FF2357B6" FontSize="12" FontWeight="SemiBold" /></Border>
                            </Grid>
                            <ListBox x:Name="FenceItemsList" SelectionMode="Extended" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource IconGridItem}">
                                <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                                <ListBox.ItemTemplate><DataTemplate><StackPanel Width="72" Height="76" VerticalAlignment="Center"><Image Source="{Binding Icon}" Width="38" Height="38" Stretch="Uniform" /><TextBlock Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="11" Margin="0,7,0,0" ToolTip="{Binding Name}" /></StackPanel></DataTemplate></ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <ScrollViewer x:Name="PagesPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="PagesTitle" Style="{StaticResource SectionTitle}" Text="Pages" />
                    <TextBlock x:Name="PagesDescription" Style="{StaticResource SectionDescription}" Text="Switch and manage desktop pages." />
                    <TextBlock x:Name="CurrentPageTitle" Style="{StaticResource GroupTitle}" Text="Current page" />
                    <TextBlock x:Name="CurrentPageValue" FontSize="38" FontWeight="SemiBold" Margin="0,0,0,22" />
                    <WrapPanel>
                        <Button x:Name="PreviousPageButton" Content="Previous page" Click="PreviousPageButton_Click" />
                        <Button x:Name="NextPageButton" Content="Next page" Click="NextPageButton_Click" />
                        <Button x:Name="NewPageButton" Content="New page" Click="NewPageButton_Click" />
                        <Button x:Name="DeletePageButton" Content="Delete empty page" Click="DeletePageButton_Click" />
                    </WrapPanel>
                    <TextBlock x:Name="PagePreviewTitle" Style="{StaticResource GroupTitle}" Text="Page preview" Margin="0,24,0,10" />
                    <TextBlock x:Name="PagePreviewHint" Foreground="#FF66717E" Text="Drag a Fence to another page." Margin="0,0,0,12" />
                    <WrapPanel x:Name="PagePreviewPanel" AllowDrop="True" />
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="LayoutsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="LayoutsTitle" Style="{StaticResource SectionTitle}" Text="Layout management" />
                    <TextBlock x:Name="LayoutsDescription" Style="{StaticResource SectionDescription}" Text="Save and restore Fence positions, pages and desktop icon assignments without changing other settings." />
                    <TextBlock x:Name="NamedLayoutsTitle" Style="{StaticResource GroupTitle}" Text="Saved layouts" />
                    <ListBox x:Name="NamedLayoutsList" Height="190" BorderBrush="#FFD7DCE2" SelectionChanged="NamedLayoutsList_SelectionChanged">
                        <ListBox.ItemTemplate><DataTemplate>
                            <Grid Margin="9,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Text="{Binding SavedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Foreground="#FF65717D"/>
                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" Foreground="#FF65717D"><Run Text="{Binding FenceCount}"/><Run Text=" Fences · "/><Run Text="{Binding PageCount}"/><Run Text=" pages"/></TextBlock>
                            </Grid>
                        </DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                    <WrapPanel Margin="0,12,0,12">
                        <Button x:Name="SaveLayoutButton" Content="Save current layout" Click="SaveLayoutButton_Click"/>
                        <Button x:Name="OverwriteLayoutButton" Content="Overwrite" Click="OverwriteLayoutButton_Click"/>
                        <Button x:Name="RestoreLayoutButton" Content="Restore" Click="RestoreLayoutButton_Click"/>
                        <Button x:Name="RenameLayoutButton" Content="Rename" Click="RenameLayoutButton_Click"/>
                        <Button x:Name="DeleteLayoutButton" Content="Delete" Click="DeleteLayoutButton_Click"/>
                    </WrapPanel>
                    <Separator Margin="0,8,0,18"/>
                    <TextBlock x:Name="SnapshotsTitle" Style="{StaticResource GroupTitle}" Text="Automatic snapshots" />
                    <TextBlock x:Name="SnapshotsDescription" Foreground="#FF66717E" Margin="0,0,0,10" Text="The newest 20 snapshots are retained." />
                    <ListBox x:Name="SnapshotsList" Height="190" BorderBrush="#FFD7DCE2" SelectionChanged="SnapshotsList_SelectionChanged">
                        <ListBox.ItemTemplate><DataTemplate>
                            <Grid Margin="9,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" HorizontalAlignment="Right" Foreground="#FF65717D"><Run Text="{Binding FenceCount}"/><Run Text=" Fences · "/><Run Text="{Binding PageCount}"/><Run Text=" pages"/></TextBlock>
                            </Grid>
                        </DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                    <Button x:Name="RestoreSnapshotButton" Content="Restore snapshot" HorizontalAlignment="Left" Margin="0,12,0,0" Click="RestoreSnapshotButton_Click"/>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="OrganizePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="OrganizeTitle" Style="{StaticResource SectionTitle}" Text="Organization" />
                    <TextBlock x:Name="OrganizeDescription" Style="{StaticResource SectionDescription}" Text="Create category Fences or organize desktop items by type." />
                    <TextBlock x:Name="CategoryTitle" Style="{StaticResource GroupTitle}" Text="Desktop organization" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="360" /></Grid.ColumnDefinitions>
                        <TextBlock x:Name="ClassificationSchemeLabel" VerticalAlignment="Center" Text="Classification scheme" />
                        <ComboBox x:Name="ClassificationSchemeComboBox" Grid.Column="1" SelectionChanged="ClassificationSchemeComboBox_SelectionChanged">
                            <ComboBoxItem Tag="Detailed" Content="Detailed by type" />
                            <ComboBoxItem Tag="Simple" Content="Simple groups" />
                        </ComboBox>
                    </Grid>
                    <Border Background="#FFF5F7F9" BorderBrush="#FFD8DEE5" BorderThickness="1" Padding="12" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock x:Name="ClassificationPreviewTitle" FontWeight="SemiBold" Text="Fences to create" />
                            <TextBlock x:Name="ClassificationPreviewText" Margin="0,7,0,0" TextWrapping="Wrap" Foreground="#FF56616D" />
                        </StackPanel>
                    </Border>
                    <WrapPanel>
                        <Button x:Name="CreateCategoriesButton" Content="Create category Fences" Click="CreateCategoriesButton_Click" Visibility="Collapsed" />
                        <Button x:Name="OrganizeDesktopButton" Content="Organize desktop by type" Click="OrganizeDesktopButton_Click" />
                        <Button x:Name="UndoOrganizeButton" Content="Undo last organization" Click="UndoOrganizeButton_Click" />
                    </WrapPanel>
                    <TextBlock x:Name="OrganizeNote" Margin="0,14,0,0" Foreground="#FF66717E" Text="Organization always asks for confirmation and never overwrites existing items." />
                    <Separator Margin="0,22,0,18" />
                    <TextBlock x:Name="RulesTitle" Style="{StaticResource GroupTitle}" Text="Automatic organization rules" />
                    <CheckBox x:Name="EnableAutoOrganizeCheckBox" Content="Automatically assign new desktop items" Click="EnableAutoOrganizeCheckBox_Click" Margin="0,0,0,14" />
                    <Grid Margin="0,0,0,14" Visibility="Collapsed">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="360" /></Grid.ColumnDefinitions>
                        <TextBlock x:Name="DefaultFenceLabel" Text="Default Fence" VerticalAlignment="Center" />
                        <ComboBox x:Name="DefaultFenceComboBox" Grid.Column="1" DisplayMemberPath="Title" SelectionChanged="DefaultFenceComboBox_SelectionChanged" />
                    </Grid>
                    <Grid Height="0" Visibility="Collapsed">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="230" /><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0">
                            <WrapPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                                <Button x:Name="AddRuleButton" Content="Add" Click="AddRuleButton_Click" />
                                <Button x:Name="DeleteRuleButton" Content="Delete" Click="DeleteRuleButton_Click" />
                            </WrapPanel>
                            <ListBox x:Name="RuleList" DisplayMemberPath="Name" SelectionChanged="RuleList_SelectionChanged" />
                        </DockPanel>
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="145" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" /><RowDefinition Height="36" /><RowDefinition Height="36" />
                                <RowDefinition Height="36" /><RowDefinition Height="36" /><RowDefinition Height="36" />
                                <RowDefinition Height="36" /><RowDefinition Height="36" />
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="RuleEnabledCheckBox" Grid.ColumnSpan="2" Content="Rule enabled" Click="RuleEditor_Changed" />
                            <TextBlock x:Name="RuleNameLabel" Grid.Row="1" Text="Rule name" VerticalAlignment="Center" /><TextBox x:Name="RuleNameTextBox" Grid.Row="1" Grid.Column="1" TextChanged="RuleEditor_Changed" />
                            <TextBlock x:Name="RuleTargetLabel" Grid.Row="2" Text="Target Fence" VerticalAlignment="Center" /><ComboBox x:Name="RuleTargetComboBox" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Title" SelectionChanged="RuleEditor_Changed" />
                            <TextBlock x:Name="RulePriorityLabel" Grid.Row="3" Text="Priority" VerticalAlignment="Center" /><TextBox x:Name="RulePriorityTextBox" Grid.Row="3" Grid.Column="1" TextChanged="RuleEditor_Changed" />
                            <TextBlock x:Name="RuleNamePatternLabel" Grid.Row="4" Text="Name pattern" VerticalAlignment="Center" /><TextBox x:Name="RuleNamePatternTextBox" Grid.Row="4" Grid.Column="1" ToolTip="Examples: report*; *invoice*" TextChanged="RuleEditor_Changed" />
                            <TextBlock x:Name="RuleExtensionsLabel" Grid.Row="5" Text="Extensions" VerticalAlignment="Center" /><TextBox x:Name="RuleExtensionsTextBox" Grid.Row="5" Grid.Column="1" ToolTip="Examples: docx; pdf; txt" TextChanged="RuleEditor_Changed" />
                            <TextBlock x:Name="RuleSizeLabel" Grid.Row="6" Text="Size range (MB)" VerticalAlignment="Center" />
                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal"><TextBox x:Name="RuleMinimumSizeTextBox" Width="90" TextChanged="RuleEditor_Changed" /><TextBlock Text=" to " VerticalAlignment="Center" /><TextBox x:Name="RuleMaximumSizeTextBox" Width="90" TextChanged="RuleEditor_Changed" /></StackPanel>
                            <CheckBox x:Name="RuleFoldersOnlyCheckBox" Grid.Row="7" Grid.Column="1" Content="Folders only" Click="RuleEditor_Changed" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="DisplayPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="PersonalizeTitle" Style="{StaticResource SectionTitle}" Text="Visibility" />
                    <TextBlock x:Name="PersonalizeDescription" Style="{StaticResource SectionDescription}" Text="Control Fence and desktop icon visibility." />
                    <CheckBox x:Name="ShowFencesCheckBox" Content="Show Fences on the desktop" FontSize="15" Click="ShowFencesCheckBox_Click" Margin="0,0,0,10" />
                    <CheckBox x:Name="DesktopDoubleClickCheckBox" Content="Double-click empty desktop to hide or show Fences" FontSize="15" Click="DesktopDoubleClickCheckBox_Click" Margin="0,0,0,26" />
                    <CheckBox x:Name="DesktopIconIntegrationCheckBox" Content="Let MiniFences manage desktop icons" FontSize="15" Click="DesktopIconIntegrationCheckBox_Click" Margin="0,0,0,26" />
                    <TextBlock x:Name="DisplayPreviewTitle" Style="{StaticResource GroupTitle}" Text="Preview" />
                    <Border x:Name="DisplayPreviewDesktop" Width="520" Height="210" HorizontalAlignment="Left" Background="#FF6D7B89" CornerRadius="7" Padding="18" MouseLeftButtonDown="DisplayPreviewDesktop_MouseLeftButtonDown">
                        <Grid>
                            <StackPanel x:Name="DisplayPreviewIcons" Orientation="Horizontal" VerticalAlignment="Top">
                                <TextBlock Text="📄" FontSize="28" Margin="4" /><TextBlock Text="📁" FontSize="28" Margin="4" /><TextBlock Text="🖼" FontSize="28" Margin="4" />
                            </StackPanel>
                            <Border x:Name="DisplayPreviewFence" Width="270" Height="115" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#DD20242A" BorderBrush="#99FFFFFF" BorderThickness="1" CornerRadius="7">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <Border Background="#CC3F7FA8" CornerRadius="7,7,0,0"><TextBlock Text="Fence" Foreground="White" Margin="10,0" VerticalAlignment="Center" FontWeight="SemiBold"/></Border>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="14,12"><TextBlock Text="📄" FontSize="28"/><TextBlock Text="📁" FontSize="28" Margin="12,0,0,0"/></StackPanel>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="DisplayPreviewStatus" VerticalAlignment="Bottom" Foreground="White" FontWeight="SemiBold" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="TabsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="TabSettingsTitle" Style="{StaticResource SectionTitle}" Text="Tabs" />
                    <TextBlock x:Name="TabsDescription" Style="{StaticResource SectionDescription}" Text="Control tab appearance and interaction." />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="360" /></Grid.ColumnDefinitions>
                        <TextBlock x:Name="TabViewLabel" Text="Tab view" VerticalAlignment="Center" />
                        <ComboBox x:Name="TabViewComboBox" Grid.Column="1" SelectionChanged="TabSettings_Changed">
                            <ComboBoxItem Tag="Compact" Content="Compact arrows" />
                            <ComboBoxItem Tag="Strip" Content="Title tabs" />
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="360" /></Grid.ColumnDefinitions>
                        <TextBlock x:Name="TabWidthLabel" Text="Tab widths" VerticalAlignment="Center" />
                        <ComboBox x:Name="TabWidthComboBox" Grid.Column="1" SelectionChanged="TabSettings_Changed">
                            <ComboBoxItem Tag="Content" Content="Fit title" />
                            <ComboBoxItem Tag="Equal" Content="Equal widths" />
                        </ComboBox>
                    </Grid>
                    <CheckBox x:Name="EnableTabCreationCheckBox" Content="Enable creating tabs" Click="TabSettings_Changed" Margin="170,0,0,10" />
                    <CheckBox x:Name="ConfirmTabCreationCheckBox" Content="Confirm before creating tabs" Click="TabSettings_Changed" Margin="170,0,0,10" />
                    <CheckBox x:Name="HoverSwitchTabsCheckBox" Content="Switch tabs on hover" Click="TabSettings_Changed" Margin="170,0,0,26" />
                    <TextBlock x:Name="TabsPreviewTitle" Style="{StaticResource GroupTitle}" Text="Preview" />
                    <Border Width="520" Height="150" HorizontalAlignment="Left" Background="#FF6D7B89" CornerRadius="7" Padding="24">
                        <Border Width="420" Height="92" Background="#DD20242A" BorderBrush="#99FFFFFF" BorderThickness="1" CornerRadius="7">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Grid x:Name="TabPreviewPanel" Background="#CC3F7FA8" />
                                <TextBlock x:Name="TabPreviewContent" Grid.Row="1" Text="Desktop" Foreground="White" FontSize="18" Margin="16,10" />
                            </Grid>
                        </Border>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="RollupPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="RollupSettingsTitle" Style="{StaticResource SectionTitle}" Text="Roll-up" />
                    <TextBlock x:Name="RollupDescription" Style="{StaticResource SectionDescription}" Text="Control Fence roll-up and expansion behavior." />
                    <CheckBox x:Name="EnableRollupCheckBox" Content="Enabled" Click="RollupSettings_Changed" Margin="0,0,0,10" />
                    <CheckBox x:Name="DoubleClickRollupCheckBox" Content="Double-click the Fence title to roll up" Click="RollupSettings_Changed" Margin="0,0,0,10" />
                    <CheckBox x:Name="AutoEdgeRollupCheckBox" Content="Automatically roll up at the top or bottom screen edge" Click="RollupSettings_Changed" Margin="0,0,0,10" />
                    <CheckBox x:Name="ClickTitleExpandCheckBox" Content="Click the title to expand" Click="RollupSettings_Changed" Margin="0,0,0,10" />
                    <CheckBox x:Name="HoverTitleExpandCheckBox" Content="Hover over the title to expand" Click="RollupSettings_Changed" Margin="0,0,0,26" />
                    <TextBlock x:Name="RollupPreviewTitle" Style="{StaticResource GroupTitle}" Text="Interactive preview" />
                    <Border Width="520" Height="190" HorizontalAlignment="Left" Background="#FF6D7B89" CornerRadius="7" Padding="24">
                        <Border x:Name="RollupPreviewFence" Width="390" HorizontalAlignment="Center" VerticalAlignment="Top" Background="#DD20242A" BorderBrush="#99FFFFFF" BorderThickness="1" CornerRadius="7"
                                MouseLeftButtonDown="RollupPreviewFence_MouseLeftButtonDown" MouseEnter="RollupPreviewFence_MouseEnter" MouseLeave="RollupPreviewFence_MouseLeave">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition x:Name="RollupPreviewContentRow" Height="82"/></Grid.RowDefinitions>
                                <Border Background="#CC3F7FA8" CornerRadius="7,7,0,0"><TextBlock x:Name="RollupPreviewHeader" Text="Fence — click or hover to preview" Foreground="White" Margin="10,0" VerticalAlignment="Center" FontWeight="SemiBold"/></Border>
                                <StackPanel x:Name="RollupPreviewContent" Grid.Row="1" Orientation="Horizontal" Margin="18,16"><TextBlock Text="📄" FontSize="30"/><TextBlock Text="📁" FontSize="30" Margin="16,0,0,0"/><TextBlock Text="🖼" FontSize="30" Margin="16,0,0,0"/></StackPanel>
                            </Grid>
                        </Border>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="AppearancePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="FenceAppearanceTitle" Style="{StaticResource SectionTitle}" Text="Fence appearance" />
                    <TextBlock x:Name="FenceAppearanceDescription" Style="{StaticResource SectionDescription}" Text="Customize colors, layout, and visual style." />
                    <ComboBox x:Name="StyleFenceComboBox"
                              Width="360"
                              HorizontalAlignment="Left"
                              DisplayMemberPath="Title"
                              SelectionChanged="StyleFenceComboBox_SelectionChanged"
                              Margin="0,0,0,18" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="BackgroundColorLabel" Text="Background color" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border x:Name="BackgroundColorSwatch" Width="34" Height="24" BorderBrush="#FF8A929C" BorderThickness="1" Margin="0,0,10,8" />
                            <Button x:Name="BackgroundColorButton" Content="Choose color" Click="BackgroundColorButton_Click" />
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="HeaderColorLabel" Text="Title bar color" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border x:Name="HeaderColorSwatch" Width="34" Height="24" BorderBrush="#FF8A929C" BorderThickness="1" Margin="0,0,10,8" />
                            <Button x:Name="HeaderColorButton" Content="Choose color" Click="HeaderColorButton_Click" />
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="360" /></Grid.ColumnDefinitions>
                        <TextBlock x:Name="TitleAlignmentLabel" Text="Title alignment" VerticalAlignment="Center" />
                        <ComboBox x:Name="TitleAlignmentComboBox" Grid.Column="1" SelectionChanged="TitleAlignmentComboBox_SelectionChanged">
                            <ComboBoxItem Tag="Left" Content="Left" />
                            <ComboBoxItem Tag="Center" Content="Center" />
                            <ComboBoxItem Tag="Right" Content="Right" />
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="360" /></Grid.ColumnDefinitions>
                        <TextBlock x:Name="FenceStyleLabel" Text="Frame style" VerticalAlignment="Center" />
                        <ComboBox x:Name="FenceStyleComboBox" Grid.Column="1" SelectionChanged="FenceStyleComboBox_SelectionChanged">
                            <ComboBoxItem Tag="Framed" Content="Framed" />
                            <ComboBoxItem Tag="Clean" Content="Clean" />
                        </ComboBox>
                    </Grid>
                    <CheckBox x:Name="ShowPathCheckBox" Content="Show path and item count" Click="ShowPathCheckBox_Click" Margin="170,0,0,14" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OpacityLabel" Text="Opacity" VerticalAlignment="Center" />
                        <Slider x:Name="OpacitySlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="100"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OpacitySlider_ValueChanged"
                                PreviewMouseLeftButtonUp="OpacitySlider_PreviewMouseLeftButtonUp"
                                LostKeyboardFocus="OpacitySlider_LostKeyboardFocus"
                                KeyUp="OpacitySlider_KeyUp"
                                VerticalAlignment="Center" />
                        <TextBlock x:Name="OpacityValueText" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                    <TextBlock x:Name="AppearancePreviewTitle" Style="{StaticResource GroupTitle}" Text="Preview" />
                    <Border Width="520" Height="150" HorizontalAlignment="Left" Margin="0,0,0,18"
                            Background="#FF6F7D8A" BorderBrush="#FFD7DCE2" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Border x:Name="PreviewFenceBorder" Width="360" Height="118" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    BorderBrush="#99FFFFFF" BorderThickness="1" CornerRadius="7">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32" />
                                        <RowDefinition x:Name="PreviewPathRow" Height="22" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border x:Name="PreviewHeader" Grid.Row="0" CornerRadius="7,7,0,0">
                                        <TextBlock x:Name="PreviewFenceTitle" Margin="11,0" VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold" Text="Desktop" />
                                    </Border>
                                    <TextBlock x:Name="PreviewPath" Grid.Row="1" Text="G:\Desktop - 12 items" Foreground="#CCDDE6EF" FontSize="11" Margin="10,3" />
                                    <Border x:Name="PreviewContent" Grid.Row="2" CornerRadius="0,0,7,7">
                                        <StackPanel Orientation="Horizontal" Margin="14,10">
                                            <StackPanel Width="74"><Image x:Name="PreviewIcon1" Width="36" Height="36" Stretch="Uniform" /><TextBlock x:Name="PreviewName1" Foreground="White" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" /></StackPanel>
                                            <StackPanel Width="74"><Image x:Name="PreviewIcon2" Width="36" Height="36" Stretch="Uniform" /><TextBlock x:Name="PreviewName2" Foreground="White" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" /></StackPanel>
                                            <StackPanel Width="74"><Image x:Name="PreviewIcon3" Width="36" Height="36" Stretch="Uniform" /><TextBlock x:Name="PreviewName3" Foreground="White" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" /></StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    <WrapPanel>
                        <Button x:Name="CopyAppearanceButton" Content="Copy appearance" Click="CopyAppearanceButton_Click" />
                        <Button x:Name="PasteAppearanceButton" Content="Paste appearance" Click="PasteAppearanceButton_Click" />
                        <Button x:Name="ResetAppearanceButton" Content="Reset appearance" Click="ResetAppearanceButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="GeneralPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="GeneralTitle" Style="{StaticResource SectionTitle}" Text="General" />
                    <TextBlock x:Name="GeneralDescription" Style="{StaticResource SectionDescription}" Text="Language and Windows startup settings." />
                    <TextBlock x:Name="LanguageTitle" Style="{StaticResource GroupTitle}" Text="Language" />
                    <ComboBox x:Name="LanguageComboBox" Width="260" HorizontalAlignment="Left" SelectionChanged="LanguageComboBox_SelectionChanged" Margin="0,0,0,26">
                        <ComboBoxItem Tag="en" Content="English" />
                        <ComboBoxItem Tag="zh-CN" Content="中文（简体）" />
                    </ComboBox>
                    <TextBlock x:Name="StartupTitle" Style="{StaticResource GroupTitle}" Text="Startup" />
                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start MiniFences with Windows" FontSize="15" Click="StartWithWindowsCheckBox_Click" Margin="0,0,0,26" />
                    <TextBlock x:Name="ShortcutsTitle" Style="{StaticResource GroupTitle}" Text="Keyboard shortcuts" />
                    <Grid Width="520" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="42" /><RowDefinition Height="42" /><RowDefinition Height="42" /><RowDefinition Height="44" /></Grid.RowDefinitions>
                        <TextBlock x:Name="PreviousPageHotkeyLabel" Text="Previous page" VerticalAlignment="Center" />
                        <TextBox x:Name="PreviousPageHotkeyTextBox" Grid.Column="1" VerticalContentAlignment="Center" />
                        <TextBlock x:Name="NextPageHotkeyLabel" Grid.Row="1" Text="Next page" VerticalAlignment="Center" />
                        <TextBox x:Name="NextPageHotkeyTextBox" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center" />
                        <TextBlock x:Name="TopmostHotkeyLabel" Grid.Row="2" Text="Pin/restore Fences" VerticalAlignment="Center" />
                        <TextBox x:Name="TopmostHotkeyTextBox" Grid.Row="2" Grid.Column="1" VerticalContentAlignment="Center" />
                        <Button x:Name="ApplyHotkeysButton" Grid.Row="3" Grid.Column="1" Content="Apply shortcuts" HorizontalAlignment="Left" Click="ApplyHotkeysButton_Click" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid x:Name="AboutPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="AboutTitle" Style="{StaticResource SectionTitle}" Text="About" />
                    <TextBlock x:Name="AboutDescription" Style="{StaticResource SectionDescription}" Text="MiniFences desktop folder containers for Windows 10/11." />
                    <TextBlock Text="MiniFences" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock x:Name="VersionText" Text="MVP development build" Foreground="#FF66717E" Margin="0,0,0,24" />
                    <WrapPanel>
                        <Button x:Name="OpenConfigButton" Content="Open config folder" Click="OpenConfigButton_Click" />
                        <Button x:Name="OpenLogButton" Content="Open log file" Click="OpenLogButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
