<UserControl x:Class="MiniFences.FenceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:s="clr-namespace:System.Windows.Shapes;assembly=PresentationFramework"
             AllowDrop="True"
             DragEnter="FenceControl_DragEnter"
             DragLeave="FenceControl_DragLeave"
             DragOver="FenceControl_DragOver"
             Drop="FenceControl_Drop"
             MouseEnter="FenceControl_MouseEnter"
             MouseLeave="FenceControl_MouseLeave"
             MinWidth="240"
             MinHeight="180">
    <UserControl.ContextMenu>
        <ContextMenu Opened="FenceContextMenu_Opened">
            <MenuItem x:Name="NewFenceMenuItem" Header="New Fence" Click="NewFenceMenuItem_Click" />
            <MenuItem x:Name="HoverExpandMenuItem" Header="Expand on Hover" IsCheckable="True" Click="HoverExpandMenuItem_Click" />
            <MenuItem x:Name="LockFenceMenuItem" Header="Lock Fence" IsCheckable="True" Click="LockFenceMenuItem_Click" />
            <MenuItem x:Name="UnstackTabMenuItem" Header="Remove from Tab Stack" Click="UnstackTabMenuItem_Click" />
            <Separator />
            <MenuItem x:Name="RenameFenceMenuItem" Header="Rename Fence" Click="RenameFenceMenuItem_Click" />
            <MenuItem x:Name="ChooseFolderMenuItem" Header="Choose Folder..." Click="ChooseFolderMenuItem_Click" />
            <MenuItem x:Name="OpenBoundFolderMenuItem" Header="Open Bound Folder" Click="OpenBoundFolderMenuItem_Click" />
            <MenuItem x:Name="MoveToPreviousPageMenuItem" Header="Move to Previous Page" Click="MoveToPreviousPageMenuItem_Click" />
            <MenuItem x:Name="MoveToNextPageMenuItem" Header="Move to Next Page" Click="MoveToNextPageMenuItem_Click" />
            <MenuItem x:Name="MoveToNewPageMenuItem" Header="Move to New Page" Click="MoveToNewPageMenuItem_Click" />
            <MenuItem x:Name="SortMenuItem" Header="Sort by">
                <MenuItem x:Name="SortNoneMenuItem" Tag="None" Header="None" IsCheckable="True" Click="SortMenuItem_Click" />
                <MenuItem x:Name="SortNameMenuItem" Tag="Name" Header="Name" IsCheckable="True" Click="SortMenuItem_Click" />
                <MenuItem x:Name="SortSizeMenuItem" Tag="Size" Header="Size" IsCheckable="True" Click="SortMenuItem_Click" />
                <MenuItem x:Name="SortTypeMenuItem" Tag="ItemType" Header="Item type" IsCheckable="True" Click="SortMenuItem_Click" />
                <MenuItem x:Name="SortModifiedMenuItem" Tag="Modified" Header="Modified" IsCheckable="True" Click="SortMenuItem_Click" />
                <MenuItem x:Name="SortCreatedMenuItem" Tag="Created" Header="Created" IsCheckable="True" Click="SortMenuItem_Click" />
                <MenuItem x:Name="SortCategoryMenuItem" Tag="Category" Header="Category" IsCheckable="True" Click="SortMenuItem_Click" />
            </MenuItem>
            <MenuItem x:Name="StyleMenuItem" Header="Style">
                <MenuItem x:Name="CopyColorMenuItem" Header="Copy Color" Click="CopyColorMenuItem_Click" />
                <MenuItem x:Name="ChooseBackgroundColorMenuItem" Header="Edit Color..." Click="ChooseBackgroundColorMenuItem_Click" />
                <MenuItem x:Name="ChooseHeaderColorMenuItem" Header="Choose Header Color..." Click="ChooseHeaderColorMenuItem_Click" />
                <Separator />
                <MenuItem x:Name="OpacityMenuItem" Header="Opacity">
                    <MenuItem Tag="0" Header="0%" IsCheckable="True" Click="OpacityMenuItem_Click" />
                    <MenuItem Tag="20" Header="20%" IsCheckable="True" Click="OpacityMenuItem_Click" />
                    <MenuItem Tag="40" Header="40%" IsCheckable="True" Click="OpacityMenuItem_Click" />
                    <MenuItem Tag="60" Header="60%" IsCheckable="True" Click="OpacityMenuItem_Click" />
                    <MenuItem Tag="80" Header="80%" IsCheckable="True" Click="OpacityMenuItem_Click" />
                    <MenuItem Tag="100" Header="100%" IsCheckable="True" Click="OpacityMenuItem_Click" />
                </MenuItem>
                <MenuItem x:Name="ResetStyleMenuItem" Header="Reset Style" Click="ResetStyleMenuItem_Click" />
            </MenuItem>
            <Separator />
            <MenuItem x:Name="DeleteFenceMenuItem" Header="Delete Fence" Click="DeleteFenceMenuItem_Click" />
        </ContextMenu>
    </UserControl.ContextMenu>

    <Border x:Name="OuterBorder"
            BorderBrush="#88FFFFFF"
            BorderThickness="1"
            CornerRadius="8"
            Background="#DD20242A"
            ClipToBounds="True"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition x:Name="ContentRow" Height="*" />
                <RowDefinition x:Name="FooterRow" Height="22" />
            </Grid.RowDefinitions>

            <Border x:Name="ContentBackground"
                    Grid.Row="1"
                    Grid.RowSpan="2"
                    Background="#DD20242A"
                    CornerRadius="0,0,8,8" />

            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="#CC3F7FA8"
                    CornerRadius="8,8,0,0"
                    Cursor="Arrow"
                    PreviewMouseLeftButtonDown="TitleBar_PreviewMouseLeftButtonDown"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseMove="TitleBar_MouseMove"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"
                    LostMouseCapture="TitleBar_LostMouseCapture">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel x:Name="TabNavigationPanel" Orientation="Horizontal" Margin="8,0,8,0"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="‹" Width="20" Foreground="White" FontSize="18" TextAlignment="Center"
                                   Cursor="Hand" ToolTip="Previous tab" MouseLeftButtonDown="PreviousTab_MouseLeftButtonDown" />
                        <TextBlock x:Name="TabStatusText" MinWidth="32" Foreground="#DDFFFFFF" FontSize="11"
                                   TextAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="›" Width="20" Foreground="White" FontSize="18" TextAlignment="Center"
                                   Cursor="Hand" ToolTip="Next tab" MouseLeftButtonDown="NextTab_MouseLeftButtonDown" />
                    </StackPanel>
                    <Grid x:Name="TabStripPanel" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Visibility="Collapsed" />
                    <Grid x:Name="MergePreview" Opacity="0" IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="1" Margin="3,3"
                                Background="#E6F59E0B" BorderBrush="#FFFFF4D6"
                                BorderThickness="2" CornerRadius="5">
                            <Border.Effect>
                                <DropShadowEffect Color="#FFFFB020" BlurRadius="14" ShadowDepth="0" Opacity="0.9" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="MergePreviewPulse" Grid.Column="1" Margin="3,3"
                                BorderBrush="White" BorderThickness="2" CornerRadius="5"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid x:Name="ContentArea" Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Row="0"
                           Margin="0,0,0,8"
                           Foreground="#CCDDE6EF"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />

                <ListView x:Name="ItemsList"
                          Grid.Row="1"
                          Background="#16FFFFFF"
                          BorderThickness="0"
                          Foreground="White"
                          SelectionMode="Extended"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ContextMenuOpening="ItemsList_ContextMenuOpening"
                          PreviewMouseRightButtonDown="ItemsList_PreviewMouseRightButtonDown"
                          PreviewMouseLeftButtonDown="ItemsList_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="ItemsList_PreviewMouseMove"
                          KeyDown="ItemsList_KeyDown">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="OpenItemMenuItem" Header="Open" Click="OpenItemMenuItem_Click" />
                            <MenuItem x:Name="RenameItemMenuItem" Header="Rename" Click="RenameItemMenuItem_Click" />
                            <MenuItem x:Name="ShowItemInExplorerMenuItem" Header="Show in Explorer" Click="ShowItemInExplorerMenuItem_Click" />
                            <MenuItem x:Name="CopyItemPathMenuItem" Header="Copy Path" Click="CopyItemPathMenuItem_Click" />
                            <Separator />
                            <MenuItem x:Name="DeleteItemMenuItem" Header="Delete" Click="DeleteItemMenuItem_Click" />
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="AllowDrop" Value="True" />
                            <Setter Property="Width" Value="86" />
                            <Setter Property="Height" Value="92" />
                            <Setter Property="Margin" Value="4" />
                            <Setter Property="Padding" Value="4" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="ToolTip" Value="{Binding FullPath}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="ItemChrome"
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                              ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemChrome" Property="Background" Value="#24FFFFFF" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemChrome" Property="Background" Value="#663F7FA8" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <EventSetter Event="MouseDoubleClick" Handler="Item_MouseDoubleClick" />
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Item_PreviewMouseLeftButtonDown" />
                            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="Item_PreviewMouseLeftButtonUp" />
                            <EventSetter Event="MouseMove" Handler="Item_MouseMove" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="Item_PreviewMouseRightButtonDown" />
                            <EventSetter Event="DragOver" Handler="Item_DragOver" />
                            <EventSetter Event="Drop" Handler="Item_Drop" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">
                                <Grid Background="Transparent">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="52" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Image Grid.Row="0"
                                           Width="42"
                                           Height="42"
                                           Source="{Binding Icon}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                    <Grid Grid.Row="1">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="15"
                                                   MaxHeight="34"
                                                   VerticalAlignment="Top" />
                                        <TextBox Visibility="Collapsed"
                                                 FontSize="12"
                                                 KeyDown="ItemRenameTextBox_KeyDown"
                                                 LostKeyboardFocus="ItemRenameTextBox_LostKeyboardFocus" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <DockPanel x:Name="FooterPanel" Grid.Row="2" Margin="8,0,24,4">
                <TextBlock x:Name="FooterHintText"
                           DockPanel.Dock="Left"
                           Foreground="#99FFFFFF"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Text="Right-click for options." />
            </DockPanel>
            <Thumb x:Name="ResizeThumb"
                   Grid.Row="0"
                   Grid.RowSpan="3"
                   Width="18"
                   Height="18"
                   Margin="0,0,4,4"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Panel.ZIndex="20"
                   Visibility="Collapsed"
                   Cursor="SizeNWSE"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="#22000000">
                            <Path Stroke="#CCFFFFFF"
                                  StrokeThickness="1.2"
                                  Data="M 3 15 L 15 3 M 9 15 L 15 9" />
                        </Grid>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</UserControl>
